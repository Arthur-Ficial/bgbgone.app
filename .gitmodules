[submodule "vendor/bgbgone"]
	path = vendor/bgbgone
	url = git@github.com:Arthur-Ficial/bgbgone.git
	# Build-time vendored dependency: `make build` regenerates the tracked
	# Sources/BuildInfo.swift and writes .build/, dirtying the working tree.
	# We pin only the commit, so ignore working-tree dirt in `git status`.
	ignore = dirty
